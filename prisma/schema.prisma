generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SeenJob {
  jobId     String   @id
  title     String
  company   String
  location  String
  link      String
  source    String   @default("linkedin")
  seenAt    DateTime @default(now())
}
